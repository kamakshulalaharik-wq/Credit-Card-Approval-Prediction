from flask import Flask, render_template, request
import os

app = Flask(__name__)

# Mock prediction logic to guarantee an error-free run out of the box
class PredictiveModel:
    def predict(self, score):
        # High credit standing score leads to approval (1), low score leads to rejection (0)
        return [1] if score >= 650 else [0]

model = PredictiveModel()

@app.route('/')
def home():
    return render_template('home.html')

@app.route('/predict_form')
def predict_form():
    return render_template('index.html')

@app.route('/predict', methods=['POST'])
def predict():
    if request.method == 'POST':
        applicant_name = request.form.get('name', 'Applicant')
        try:
            credit_score = int(request.form.get('score', 0))
        except ValueError:
            credit_score = 0
            
        prediction = model.predict(credit_score)[0]
        outcome = "APPROVED" if prediction == 1 else "REJECTED"
        
        return render_template('result.html', name=applicant_name, result=outcome)

if __name__ == '__main__':
    # Ensure templates folder exists dynamically
    os.makedirs('templates', exist_ok=True)
    app.run(debug=True, host='127.0.0.1', port=5000)
